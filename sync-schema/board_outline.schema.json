{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Board Outline",
  "description": "Board outline geometry, holes, slots, and cutouts",
  "type": "object",
  "properties": {
    "schema_version": { "type": "string" },
    "outer_boundary": {
      "type": "array",
      "description": "Ordered segments forming the outer board outline (closed loop)",
      "items": { "$ref": "#/definitions/segment" }
    },
    "holes": {
      "type": "array",
      "description": "Mounting holes and slots",
      "items": { "$ref": "#/definitions/hole" }
    },
    "cutouts": {
      "type": "array",
      "description": "Arbitrary internal cutouts, each a closed loop of segments",
      "items": {
        "type": "array",
        "items": { "$ref": "#/definitions/segment" }
      }
    }
  },
  "required": ["schema_version", "outer_boundary"],
  "definitions": {
    "segment": {
      "oneOf": [
        {
          "title": "Line",
          "type": "object",
          "properties": {
            "type": { "const": "line" },
            "start": { "$ref": "#/definitions/point" },
            "end": { "$ref": "#/definitions/point" }
          },
          "required": ["type", "start", "end"]
        },
        {
          "title": "Arc",
          "type": "object",
          "properties": {
            "type": { "const": "arc" },
            "start": { "$ref": "#/definitions/point" },
            "mid": { "$ref": "#/definitions/point" },
            "end": { "$ref": "#/definitions/point" }
          },
          "required": ["type", "start", "mid", "end"]
        }
      ]
    },
    "hole": {
      "oneOf": [
        {
          "title": "Round hole",
          "type": "object",
          "properties": {
            "type": { "const": "round" },
            "center": { "$ref": "#/definitions/point" },
            "diameter_mm": { "type": "number" }
          },
          "required": ["type", "center", "diameter_mm"]
        },
        {
          "title": "Slot",
          "type": "object",
          "properties": {
            "type": { "const": "slot" },
            "center": { "$ref": "#/definitions/point" },
            "width_mm": { "type": "number", "description": "Narrow dimension" },
            "length_mm": { "type": "number", "description": "Long dimension (center to center of end radii + width)" },
            "angle_deg": { "type": "number", "description": "Rotation of the long axis, 0 = horizontal" }
          },
          "required": ["type", "center", "width_mm", "length_mm", "angle_deg"]
        }
      ]
    },
    "point": {
      "type": "object",
      "properties": {
        "x_mm": { "type": "number" },
        "y_mm": { "type": "number" }
      },
      "required": ["x_mm", "y_mm"]
    }
  }
}
